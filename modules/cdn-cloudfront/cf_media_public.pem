
# modules/cdn-cloudfront/cf_media_public.pem
#
# PLACEHOLDER — replace with a real RSA public key before applying.
#
# HOW TO GENERATE:
#   # Generate private key (keep this SECRET — store in Secrets Manager or 1Password)
#   openssl genrsa -out cf_media_private.pem 2048
#
#   # Extract public key (this file — safe to commit)
#   openssl rsa -pubout -in cf_media_private.pem -out cf_media_public.pem
#
# The private key is used by your application to generate signed URLs.
# The public key is uploaded to CloudFront so it can verify signatures.
#
# Store the private key in AWS Secrets Manager:
#   aws secretsmanager create-secret \
#     --name openedx/prod/cloudfront/media-signing-private-key \
#     --secret-string file://cf_media_private.pem
#
# Then delete cf_media_private.pem from disk.
#
# ROTATE ANNUALLY: Generate a new key pair, update this file, re-apply.
# CloudFront supports multiple keys in a key group during rotation.
#
# NOTE: enable_signed_media_urls = false in dev/staging skips this file entirely.
# Only prod reads it. See edge-auth.tf count = var.enable_signed_media_urls ? 1 : 0

-----BEGIN PUBLIC KEY-----
